generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Invoice {
  invoiceId Int       @id @default(autoincrement()) @map("invoice_id")
  repairId  Int       @unique(map: "repair_id") @map("repair_id")
  issueDate DateTime? @map("issue_date") @db.DateTime(0)
  subtotal  Decimal?  @db.Decimal(10, 2)
  tax       Decimal?  @db.Decimal(10, 2)
  discount  Decimal?  @db.Decimal(10, 2)
  total     Decimal?  @db.Decimal(10, 2)
  repair    Repair    @relation(fields: [repairId], references: [repairId], onDelete: NoAction, onUpdate: NoAction, map: "INVOICE_ibfk_1")
  payments  Payment[]

  @@map("INVOICE")
}

model Labor {
  laborId     Int      @id @default(autoincrement()) @map("labor_id")
  repairId    Int      @map("repair_id")
  description String?  @db.VarChar(255)
  hours       Decimal? @db.Decimal(5, 2)
  hourlyRate  Decimal? @map("hourly_rate") @db.Decimal(10, 2)
  performedAt DateTime @map("performed_at") @db.DateTime(0)
  repair      Repair   @relation(fields: [repairId], references: [repairId], onDelete: NoAction, onUpdate: NoAction, map: "LABOR_ibfk_1")

  @@index([repairId], map: "repair_id")
  @@map("LABOR")
}

model Payment {
  paymentId       Int            @id @default(autoincrement()) @map("payment_id")
  invoiceId       Int            @map("invoice_id")
  paymentDate     DateTime       @map("payment_date") @db.DateTime(0)
  amount          Decimal        @db.Decimal(10, 2)
  paymentMethodId Int?           @map("payment_method_id")
  reference       String?        @db.VarChar(255)
  invoice         Invoice        @relation(fields: [invoiceId], references: [invoiceId], onDelete: NoAction, onUpdate: NoAction, map: "PAYMENT_ibfk_1")
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [paymentMethodId], onDelete: NoAction, onUpdate: NoAction, map: "PAYMENT_ibfk_2")

  @@index([invoiceId], map: "invoice_id")
  @@index([paymentMethodId], map: "payment_method_id")
  @@map("PAYMENT")
}

model PaymentMethod {
  paymentMethodId Int       @id @default(autoincrement()) @map("payment_method_id")
  name            String    @unique(map: "name") @db.VarChar(50)
  payments        Payment[]

  @@map("PAYMENT_METHOD")
}

model Piece {
  pieceId     Int          @id @default(autoincrement()) @map("piece_id")
  name        String       @db.VarChar(255)
  details     String?      @db.Text
  repairParts RepairPart[]
  warehouses  Warehouse[]

  @@map("PIECE")
}

model Position {
  positionId Int        @id @default(autoincrement()) @map("position_id")
  name       String     @unique(map: "name") @db.VarChar(255)
  employees  Employee[]

  @@map("POSITION")
}

model Product {
  productId      Int           @id @default(autoincrement()) @map("product_id")
  typeId         Int           @map("type_id")
  manufacturer   String?       @db.VarChar(255)
  model          String?       @db.VarChar(255)
  productionYear Int?          @map("production_year")
  name           String?       @db.VarChar(255)
  photoUrl       String?       @map("photo_url") @db.VarChar(255)
  productType    ProductType   @relation(fields: [typeId], references: [typeId], onDelete: NoAction, onUpdate: NoAction, map: "PRODUCT_ibfk_2")
  repairs        Repair[]
  userProducts   UserProduct[]

  @@index([typeId], map: "type_id")
  @@map("PRODUCT")
}

model ProductType {
  typeId   Int       @id @default(autoincrement()) @map("type_id")
  name     String    @unique(map: "name") @db.VarChar(255)
  products Product[]

  @@map("PRODUCT_TYPE")
}

model Repair {
  repairId           Int          @id @default(autoincrement()) @map("repair_id")
  productId          Int          @map("product_id")
  shopId             Int          @map("shop_id")
  statusId           Int          @map("status_id")
  estimatedHours     Decimal?     @map("estimated_hours") @db.Decimal(5, 2)
  workedHours        Decimal?     @map("worked_hours") @db.Decimal(5, 2)
  receivedDate       DateTime?    @map("received_date") @db.DateTime(0)
  finishDate         DateTime?    @map("finish_date") @db.DateTime(0)
  returnDate         DateTime?    @map("return_date") @db.DateTime(0)
  notes              String?      @db.Text
  problemDescription String?      @map("problem_description") @db.Text
  assignments        Assignment[]
  invoice            Invoice?
  labourEntries      Labor[]
  product            Product      @relation(fields: [productId], references: [productId], onDelete: NoAction, onUpdate: NoAction, map: "REPAIR_ibfk_1")
  shop               Shop         @relation(fields: [shopId], references: [shopId], onDelete: NoAction, onUpdate: NoAction, map: "REPAIR_ibfk_2")
  status             Status       @relation(fields: [statusId], references: [statusId], onDelete: NoAction, onUpdate: NoAction, map: "REPAIR_ibfk_3")
  repairParts        RepairPart[]

  @@index([productId], map: "product_id")
  @@index([shopId], map: "shop_id")
  @@index([statusId], map: "status_id")
  @@map("REPAIR")
}

model RepairPart {
  repairId  Int      @map("repair_id")
  pieceId   Int      @map("piece_id")
  quantity  Int
  unitPrice Decimal? @map("unit_price") @db.Decimal(10, 2)
  addedAt   DateTime @map("added_at") @db.DateTime(0)
  repair    Repair   @relation(fields: [repairId], references: [repairId], onDelete: NoAction, onUpdate: NoAction, map: "REPAIR_PART_ibfk_1")
  piece     Piece    @relation(fields: [pieceId], references: [pieceId], onDelete: NoAction, onUpdate: NoAction, map: "REPAIR_PART_ibfk_2")

  @@id([repairId, pieceId])
  @@index([pieceId], map: "piece_id")
  @@map("REPAIR_PART")
}

model Role {
  roleId Int    @id @default(autoincrement()) @map("role_id")
  name   String @unique(map: "name") @db.VarChar(255)
  users  User[]

  @@map("ROLE")
}

model Shop {
  shopId      Int         @id @default(autoincrement()) @map("shop_id")
  name        String      @db.VarChar(255)
  address     String?     @db.VarChar(255)
  phoneNumber String?     @map("phone_number") @db.VarChar(255)
  email       String?     @unique(map: "email") @db.VarChar(255)
  photoUrl    String?     @map("photo_url") @db.VarChar(255)
  employees   Employee[]
  repairs     Repair[]
  warehouses  Warehouse[]

  @@map("SHOP")
}

model Status {
  statusId Int      @id @default(autoincrement()) @map("status_id")
  name     String   @unique(map: "name") @db.VarChar(255)
  repairs  Repair[]

  @@map("STATUS")
}

model User {
  userId         Int           @id @default(autoincrement()) @map("user_id")
  roleId         Int           @map("role_id")
  firstName      String        @map("first_name") @db.VarChar(255)
  middleName     String?       @map("middle_name") @db.VarChar(255)
  lastName       String        @map("last_name") @db.VarChar(255)
  secondLastName String        @map("second_last_name") @db.VarChar(255)
  email          String?       @unique(map: "email") @db.VarChar(255)
  passwordHash   String?       @map("password_hash") @db.VarChar(255)
  phoneNumber    String?       @map("phone_number") @db.VarChar(20)
  employees      Employee[]
  role           Role          @relation(fields: [roleId], references: [roleId], onDelete: NoAction, onUpdate: NoAction, map: "USER_ibfk_1")
  userProducts   UserProduct[]

  @@index([roleId], map: "role_id")
  @@map("USER")
}

model Warehouse {
  shopId   Int     @map("shop_id")
  pieceId  Int     @map("piece_id")
  quantity Int
  notes    String? @db.Text
  shop     Shop    @relation(fields: [shopId], references: [shopId], onDelete: NoAction, onUpdate: NoAction, map: "WAREHOUSE_ibfk_1")
  piece    Piece   @relation(fields: [pieceId], references: [pieceId], onDelete: NoAction, onUpdate: NoAction, map: "WAREHOUSE_ibfk_2")

  @@id([shopId, pieceId])
  @@index([pieceId], map: "piece_id")
  @@map("WAREHOUSE")
}

model UserProduct {
  productId    Int     @map("product_id")
  ownerId      Int     @map("owner_id")
  serialNumber String? @map("serial_number") @db.VarChar(255)
  name         String? @db.VarChar(255)
  user         User    @relation(fields: [ownerId], references: [userId], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_product_owner")
  product      Product @relation(fields: [productId], references: [productId], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_product_product")

  @@id([productId, ownerId])
  @@index([ownerId], map: "fk_user_product_owner")
  @@map("USER_PRODUCT")
}

model Assignment {
  assignmentId Int       @id @default(autoincrement()) @map("assignment_id")
  repairId     Int       @map("repair_id")
  userId       Int       @map("user_id")
  shopId       Int       @map("shop_id")
  assignedAt   DateTime  @map("assigned_at") @db.DateTime(0)
  finishedAt   DateTime? @map("finished_at") @db.DateTime(0)
  repair       Repair    @relation(fields: [repairId], references: [repairId], onDelete: NoAction, onUpdate: NoAction, map: "ASSIGNMENT_ibfk_1")
  employee     Employee  @relation(fields: [shopId, userId], references: [shopId, userId], onDelete: NoAction, onUpdate: NoAction, map: "ASSIGNMENT_ibfk_2")

  @@index([repairId], map: "repair_id")
  @@index([shopId, userId], map: "shop_id")
  @@map("ASSIGNMENT")
}

model Employee {
  shopId      Int          @map("shop_id")
  userId      Int          @map("user_id")
  positionId  Int          @map("position_id")
  assignments Assignment[]
  shop        Shop         @relation(fields: [shopId], references: [shopId], onDelete: NoAction, onUpdate: NoAction, map: "EMPLOYEE_ibfk_1")
  user        User         @relation(fields: [userId], references: [userId], onDelete: NoAction, onUpdate: NoAction, map: "EMPLOYEE_ibfk_2")
  position    Position     @relation(fields: [positionId], references: [positionId], onDelete: NoAction, onUpdate: NoAction, map: "EMPLOYEE_ibfk_3")

  @@id([shopId, userId])
  @@index([positionId], map: "position_id")
  @@index([userId], map: "user_id")
  @@map("EMPLOYEE")
}
