generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model INVOICE {
  invoice_id Int       @id
  repair_id  Int       @unique(map: "repair_id")
  issue_date DateTime? @db.DateTime(0)
  subtotal   Decimal?  @db.Decimal(10, 2)
  tax        Decimal?  @db.Decimal(10, 2)
  discount   Decimal?  @db.Decimal(10, 2)
  total      Decimal?  @db.Decimal(10, 2)
  REPAIR     REPAIR    @relation(fields: [repair_id], references: [repair_id], onDelete: NoAction, onUpdate: NoAction, map: "INVOICE_ibfk_1")
  PAYMENT    PAYMENT[]
}

model LABOR {
  labor_id     Int      @id
  repair_id    Int
  description  String?  @db.VarChar(255)
  hours        Decimal? @db.Decimal(5, 2)
  hourly_rate  Decimal? @db.Decimal(10, 2)
  performed_at DateTime @db.DateTime(0)
  REPAIR       REPAIR   @relation(fields: [repair_id], references: [repair_id], onDelete: NoAction, onUpdate: NoAction, map: "LABOR_ibfk_1")

  @@index([repair_id], map: "repair_id")
}

model PAYMENT {
  payment_id        Int             @id
  invoice_id        Int
  payment_date      DateTime        @db.DateTime(0)
  amount            Decimal         @db.Decimal(10, 2)
  payment_method_id Int?
  reference         String?         @db.VarChar(255)
  INVOICE           INVOICE         @relation(fields: [invoice_id], references: [invoice_id], onDelete: NoAction, onUpdate: NoAction, map: "PAYMENT_ibfk_1")
  PAYMENT_METHOD    PAYMENT_METHOD? @relation(fields: [payment_method_id], references: [payment_method_id], onDelete: NoAction, onUpdate: NoAction, map: "PAYMENT_ibfk_2")

  @@index([invoice_id], map: "invoice_id")
  @@index([payment_method_id], map: "payment_method_id")
}

model PAYMENT_METHOD {
  payment_method_id Int       @id
  name              String?   @db.VarChar(50)
  PAYMENT           PAYMENT[]
}

model PIECE {
  piece_id    Int           @id
  name        String        @db.VarChar(255)
  details     String?       @db.Text
  REPAIR_PART REPAIR_PART[]
  WAREHOUSE   WAREHOUSE[]
}

model POSITION {
  position_id Int         @id
  name        String      @unique(map: "name") @db.VarChar(255)
  SHOP_USER   SHOP_USER[]
}

model PRODUCT {
  product_id      Int          @id
  owner_id        Int
  type_id         Int
  manufacturer    String?      @db.VarChar(255)
  model           String?      @db.VarChar(255)
  production_year Int?
  serial_number   String?      @db.VarChar(255)
  name            String?      @db.VarChar(255)
  USER            USER         @relation(fields: [owner_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "PRODUCT_ibfk_1")
  PRODUCT_TYPE    PRODUCT_TYPE @relation(fields: [type_id], references: [type_id], onDelete: NoAction, onUpdate: NoAction, map: "PRODUCT_ibfk_2")
  REPAIR          REPAIR[]

  @@index([owner_id], map: "owner_id")
  @@index([type_id], map: "type_id")
}

model PRODUCT_TYPE {
  type_id Int       @id
  name    String    @unique(map: "name") @db.VarChar(255)
  PRODUCT PRODUCT[]
}

model REPAIR {
  repair_id           Int                 @id
  product_id          Int
  shop_id             Int
  status_id           Int
  estimated_hours     Decimal?            @db.Decimal(5, 2)
  worked_hours        Decimal?            @db.Decimal(5, 2)
  received_date       DateTime?           @db.DateTime(0)
  finish_date         DateTime?           @db.DateTime(0)
  return_date         DateTime?           @db.DateTime(0)
  notes               String?             @db.Text
  problem_description String?             @db.Text
  INVOICE             INVOICE?
  LABOR               LABOR[]
  PRODUCT             PRODUCT             @relation(fields: [product_id], references: [product_id], onDelete: NoAction, onUpdate: NoAction, map: "REPAIR_ibfk_1")
  SHOP                SHOP                @relation(fields: [shop_id], references: [shop_id], onDelete: NoAction, onUpdate: NoAction, map: "REPAIR_ibfk_2")
  STATUS              STATUS              @relation(fields: [status_id], references: [status_id], onDelete: NoAction, onUpdate: NoAction, map: "REPAIR_ibfk_3")
  REPAIR_ASSIGNMENT   REPAIR_ASSIGNMENT[]
  REPAIR_PART         REPAIR_PART[]

  @@index([product_id], map: "product_id")
  @@index([shop_id], map: "shop_id")
  @@index([status_id], map: "status_id")
}

model REPAIR_ASSIGNMENT {
  repair_id    Int
  user_id      Int
  assigned_at  DateTime  @db.DateTime(0)
  completed_at DateTime? @db.DateTime(0)
  REPAIR       REPAIR    @relation(fields: [repair_id], references: [repair_id], onDelete: NoAction, onUpdate: NoAction, map: "REPAIR_ASSIGNMENT_ibfk_1")
  USER         USER      @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "REPAIR_ASSIGNMENT_ibfk_2")

  @@id([repair_id, user_id])
  @@index([user_id], map: "user_id")
}

model REPAIR_PART {
  repair_id  Int
  piece_id   Int
  quantity   Int
  unit_price Decimal? @db.Decimal(10, 2)
  added_at   DateTime @db.DateTime(0)
  REPAIR     REPAIR   @relation(fields: [repair_id], references: [repair_id], onDelete: NoAction, onUpdate: NoAction, map: "REPAIR_PART_ibfk_1")
  PIECE      PIECE    @relation(fields: [piece_id], references: [piece_id], onDelete: NoAction, onUpdate: NoAction, map: "REPAIR_PART_ibfk_2")

  @@id([repair_id, piece_id])
  @@index([piece_id], map: "piece_id")
}

model ROLE {
  role_id Int    @id
  name    String @unique(map: "name") @db.VarChar(255)
  USER    USER[]
}

model SHOP {
  shop_id      Int         @id
  name         String      @db.VarChar(255)
  address      String?     @db.VarChar(255)
  phone_number String?     @db.VarChar(255)
  email        String?     @unique(map: "email") @db.VarChar(255)
  photo_url    String?     @db.VarChar(255)
  REPAIR       REPAIR[]
  SHOP_USER    SHOP_USER[]
  WAREHOUSE    WAREHOUSE[]
}

model SHOP_USER {
  shop_id     Int
  user_id     Int
  position_id Int
  SHOP        SHOP     @relation(fields: [shop_id], references: [shop_id], onDelete: NoAction, onUpdate: NoAction, map: "SHOP_USER_ibfk_1")
  USER        USER     @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "SHOP_USER_ibfk_2")
  POSITION    POSITION @relation(fields: [position_id], references: [position_id], onDelete: NoAction, onUpdate: NoAction, map: "SHOP_USER_ibfk_3")

  @@id([shop_id, user_id])
  @@index([position_id], map: "position_id")
  @@index([user_id], map: "user_id")
}

model STATUS {
  status_id Int      @id
  name      String   @unique(map: "name") @db.VarChar(255)
  REPAIR    REPAIR[]
}

model USER {
  user_id           Int                 @id
  role_id           Int
  first_name        String              @db.VarChar(255)
  middle_name       String?             @db.VarChar(255)
  last_name         String              @db.VarChar(255)
  second_last_name  String              @db.VarChar(255)
  email             String?             @unique(map: "email") @db.VarChar(255)
  password_hash     String?             @db.VarChar(255)
  phone_number      String?             @db.VarChar(255)
  PRODUCT           PRODUCT[]
  REPAIR_ASSIGNMENT REPAIR_ASSIGNMENT[]
  SHOP_USER         SHOP_USER[]
  ROLE              ROLE                @relation(fields: [role_id], references: [role_id], onDelete: NoAction, onUpdate: NoAction, map: "USER_ibfk_1")

  @@index([role_id], map: "role_id")
}

model WAREHOUSE {
  shop_id  Int
  piece_id Int
  quantity Int
  notes    String? @db.Text
  SHOP     SHOP    @relation(fields: [shop_id], references: [shop_id], onDelete: NoAction, onUpdate: NoAction, map: "WAREHOUSE_ibfk_1")
  PIECE    PIECE   @relation(fields: [piece_id], references: [piece_id], onDelete: NoAction, onUpdate: NoAction, map: "WAREHOUSE_ibfk_2")

  @@id([shop_id, piece_id])
  @@index([piece_id], map: "piece_id")
}
