generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Invoice {
  invoiceId Int       @id @map("invoice_id")
  repairId  Int       @unique(map: "repair_id") @map("repair_id")
  issueDate DateTime? @db.DateTime(0) @map("issue_date")
  subtotal  Decimal?  @db.Decimal(10, 2)
  tax       Decimal?  @db.Decimal(10, 2)
  discount  Decimal?  @db.Decimal(10, 2)
  total     Decimal?  @db.Decimal(10, 2)
  repair    Repair    @relation(fields: [repairId], references: [repairId], onDelete: NoAction, onUpdate: NoAction, map: "INVOICE_ibfk_1")
  payments  Payment[]

  @@map("INVOICE")
}

model Labor {
  laborId     Int      @id @map("labor_id")
  repairId    Int      @map("repair_id")
  description String?  @db.VarChar(255)
  hours       Decimal? @db.Decimal(5, 2)
  hourlyRate  Decimal? @db.Decimal(10, 2)
  performedAt DateTime @db.DateTime(0) @map("performed_at")
  repair      Repair   @relation(fields: [repairId], references: [repairId], onDelete: NoAction, onUpdate: NoAction, map: "LABOR_ibfk_1")

  @@index([repairId], map: "repair_id")
  @@map("LABOR")
}

model Payment {
  paymentId       Int           @id @map("payment_id")
  invoiceId       Int           @map("invoice_id")
  paymentDate     DateTime      @db.DateTime(0) @map("payment_date")
  amount          Decimal       @db.Decimal(10, 2)
  paymentMethodId Int?          @map("payment_method_id")
  reference       String?       @db.VarChar(255)
  invoice         Invoice       @relation(fields: [invoiceId], references: [invoiceId], onDelete: NoAction, onUpdate: NoAction, map: "PAYMENT_ibfk_1")
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [paymentMethodId], onDelete: NoAction, onUpdate: NoAction, map: "PAYMENT_ibfk_2")

  @@index([invoiceId], map: "invoice_id")
  @@index([paymentMethodId], map: "payment_method_id")
  @@map("PAYMENT")
}

model PaymentMethod {
  paymentMethodId Int       @id @map("payment_method_id")
  name            String?   @db.VarChar(50)
  payments        Payment[]

  @@map("PAYMENT_METHOD")
}

model Piece {
  pieceId    Int      @id @map("piece_id")
  name       String   @db.VarChar(255)
  details    String?  @db.Text
  repairPart RepairPart[]
  warehouse  Warehouse[]

  @@map("PIECE")
}

model Position {
  positionId Int        @id @map("position_id")
  name       String     @unique(map: "name") @db.VarChar(255)
  shopUsers  ShopUser[]

  @@map("POSITION")
}

model Product {
  productId      Int          @id @map("product_id")
  ownerId        Int          @map("owner_id")
  typeId         Int          @map("type_id")
  manufacturer   String?      @db.VarChar(255)
  model          String?      @db.VarChar(255)
  productionYear Int?         @map("production_year")
  serialNumber   String?      @db.VarChar(255) @map("serial_number")
  name           String?      @db.VarChar(255)
  user           User         @relation(fields: [ownerId], references: [userId], onDelete: NoAction, onUpdate: NoAction, map: "PRODUCT_ibfk_1")
  productType    ProductType  @relation(fields: [typeId], references: [typeId], onDelete: NoAction, onUpdate: NoAction, map: "PRODUCT_ibfk_2")
  repairs        Repair[]

  @@index([ownerId], map: "owner_id")
  @@index([typeId], map: "type_id")
  @@map("PRODUCT")
}

model ProductType {
  typeId  Int       @id @map("type_id")
  name    String    @unique(map: "name") @db.VarChar(255)
  product Product[]

  @@map("PRODUCT_TYPE")
}

model Repair {
  repairId           Int                 @id @map("repair_id")
  productId          Int                 @map("product_id")
  shopId             Int                 @map("shop_id")
  statusId           Int                 @map("status_id")
  estimatedHours     Decimal?            @db.Decimal(5, 2) @map("estimated_hours")
  workedHours        Decimal?            @db.Decimal(5, 2) @map("worked_hours")
  receivedDate       DateTime?           @db.DateTime(0) @map("received_date")
  finishDate         DateTime?           @db.DateTime(0) @map("finish_date")
  returnDate         DateTime?           @db.DateTime(0) @map("return_date")
  notes              String?             @db.Text
  problemDescription String?             @db.Text @map("problem_description")
  invoice            Invoice?
  labor              Labor[]
  product            Product             @relation(fields: [productId], references: [productId], onDelete: NoAction, onUpdate: NoAction, map: "REPAIR_ibfk_1")
  shop               Shop                @relation(fields: [shopId], references: [shopId], onDelete: NoAction, onUpdate: NoAction, map: "REPAIR_ibfk_2")
  status             Status              @relation(fields: [statusId], references: [statusId], onDelete: NoAction, onUpdate: NoAction, map: "REPAIR_ibfk_3")
  repairAssignments  RepairAssignment[]
  repairParts        RepairPart[]

  @@index([productId], map: "product_id")
  @@index([shopId], map: "shop_id")
  @@index([statusId], map: "status_id")
  @@map("REPAIR")
}

model RepairAssignment {
  repairId    Int
  userId      Int
  assignedAt  DateTime  @db.DateTime(0) @map("assigned_at")
  completedAt DateTime? @db.DateTime(0) @map("completed_at")
  repair      Repair    @relation(fields: [repairId], references: [repairId], onDelete: NoAction, onUpdate: NoAction, map: "REPAIR_ASSIGNMENT_ibfk_1")
  user        User      @relation(fields: [userId], references: [userId], onDelete: NoAction, onUpdate: NoAction, map: "REPAIR_ASSIGNMENT_ibfk_2")

  @@id([repairId, userId])
  @@index([userId], map: "user_id")
  @@map("REPAIR_ASSIGNMENT")
}

model RepairPart {
  repairId  Int
  pieceId   Int
  quantity  Int
  unitPrice Decimal? @db.Decimal(10, 2) @map("unit_price")
  addedAt   DateTime @db.DateTime(0) @map("added_at")
  repair    Repair   @relation(fields: [repairId], references: [repairId], onDelete: NoAction, onUpdate: NoAction, map: "REPAIR_PART_ibfk_1")
  piece     Piece    @relation(fields: [pieceId], references: [pieceId], onDelete: NoAction, onUpdate: NoAction, map: "REPAIR_PART_ibfk_2")

  @@id([repairId, pieceId])
  @@index([pieceId], map: "piece_id")
  @@map("REPAIR_PART")
}

model Role {
  roleId Int    @id @map("role_id")
  name   String @unique(map: "name") @db.VarChar(255)
  users  User[]

  @@map("ROLE")
}

model Shop {
  shopId      Int         @id @map("shop_id")
  name        String      @db.VarChar(255)
  address     String?     @db.VarChar(255)
  phoneNumber String?     @db.VarChar(255) @map("phone_number")
  email       String?     @unique(map: "email") @db.VarChar(255)
  photoUrl    String?     @db.VarChar(255) @map("photo_url")
  repairs     Repair[]
  shopUsers   ShopUser[]
  warehouse   Warehouse[]

  @@map("SHOP")
}

model ShopUser {
  shopId     Int
  userId     Int
  positionId Int
  shop       Shop     @relation(fields: [shopId], references: [shopId], onDelete: NoAction, onUpdate: NoAction, map: "SHOP_USER_ibfk_1")
  user       User     @relation(fields: [userId], references: [userId], onDelete: NoAction, onUpdate: NoAction, map: "SHOP_USER_ibfk_2")
  position   Position @relation(fields: [positionId], references: [positionId], onDelete: NoAction, onUpdate: NoAction, map: "SHOP_USER_ibfk_3")

  @@id([shopId, userId])
  @@index([positionId], map: "position_id")
  @@index([userId], map: "user_id")
  @@map("SHOP_USER")
}

model Status {
  statusId Int      @id @map("status_id")
  name     String   @unique(map: "name") @db.VarChar(255)
  repairs  Repair[]

  @@map("STATUS")
}

model User {
  userId           Int                 @id @map("user_id")
  roleId           Int                 @map("role_id")
  firstName        String              @db.VarChar(255) @map("first_name")
  middleName       String?             @db.VarChar(255) @map("middle_name")
  lastName         String              @db.VarChar(255) @map("last_name")
  secondLastName   String              @db.VarChar(255) @map("second_last_name")
  email            String?             @unique(map: "email") @db.VarChar(255)
  passwordHash     String?             @db.VarChar(255) @map("password_hash")
  phoneNumber      String?             @db.VarChar(255) @map("phone_number")
  products         Product[]
  repairAssignments RepairAssignment[]
  shopUsers        ShopUser[]
  role             Role                @relation(fields: [roleId], references: [roleId], onDelete: NoAction, onUpdate: NoAction, map: "USER_ibfk_1")

  @@index([roleId], map: "role_id")
  @@map("USER")
}

model Warehouse {
  shopId  Int
  pieceId Int
  quantity Int
  notes   String? @db.Text
  shop    Shop   @relation(fields: [shopId], references: [shopId], onDelete: NoAction, onUpdate: NoAction, map: "WAREHOUSE_ibfk_1")
  piece   Piece  @relation(fields: [pieceId], references: [pieceId], onDelete: NoAction, onUpdate: NoAction, map: "WAREHOUSE_ibfk_2")

  @@id([shopId, pieceId])
  @@index([pieceId], map: "piece_id")
  @@map("WAREHOUSE")
}